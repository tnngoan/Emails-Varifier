{
  "name": "email-verifier",
  "version": "1.0.0",
  "description": "Production-ready bulk email verification system",
  "type": "module",
  "main": "dist/api/server.js",
  "scripts": {
    "start:api": "tsx src/api/server.ts",
    "start:worker": "tsx src/worker/worker.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker/worker.ts",
    "build": "tsc --project tsconfig.json",
    "build:start:api": "yarn build && node dist/api/server.js",
    "build:start:worker": "yarn build && node dist/worker/worker.js",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "test:bulk": "tsx scripts/bulk-test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "7",
    "@fastify/swagger": "^8.14.0",
    "bullmq": "^5.4.2",
    "fastify": "^4.26.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
