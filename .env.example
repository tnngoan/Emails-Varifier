# ─── Email Verifier — Environment Variables ───────────────────────────────────
# Copy to .env and fill in values before running locally or in production.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3003
MAX_EMAILS_PER_REQUEST=100000
LOG_LEVEL=info                  # trace | debug | info | warn | error

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_verifier
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QUEUE_NAME=email-verification

# ── SMTP Verification ─────────────────────────────────────────────────────────
# CRITICAL: SMTP_HELO_HOST must match the PTR (reverse DNS) record of the
# server's public IP. MX servers reject EHLO from mismatched hosts.
SMTP_HELO_HOST=verifier.yourdomain.com

# Probe address — does not need to be a real mailbox
SMTP_FROM_ADDRESS=probe@verifier.yourdomain.com

# Socket timeout in milliseconds (recommended: 5000–10000)
SMTP_TIMEOUT_MS=8000

# Standard SMTP port for direct MX checks (do NOT use 587 or 465 here)
SMTP_PORT=25

# ── Worker ────────────────────────────────────────────────────────────────────
# Max concurrent jobs per worker PROCESS instance
# Total system concurrency = WORKER_CONCURRENCY × number_of_worker_containers
WORKER_CONCURRENCY=50

# BullMQ-level retry attempts (separate from greylist retries)
WORKER_MAX_RETRIES=3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# TTL (seconds) for the per-domain Redis concurrency counter
DOMAIN_RATE_WINDOW_SEC=60

# Max simultaneous SMTP connections to any single unknown domain
DEFAULT_MAX_CONCURRENT=10

# ── Infrastructure Notes ──────────────────────────────────────────────────────
# For SMTP verification to work in production:
#
# 1. Outbound TCP port 25 must be unblocked on your host/VPS.
#    Most cloud providers (AWS EC2, GCP, Azure) block port 25 by default.
#    You must request an egress lift or use a dedicated SMTP-capable VPS.
#
# 2. Set up a PTR (rDNS) record:
#    Your public IP  →  verifier.yourdomain.com
#
# 3. Set up a forward DNS record:
#    verifier.yourdomain.com  →  Your public IP
#
# 4. Use a static IP — rotating IPs accumulate spam-list hits faster.
#
# 5. Consider registering your IP with major feedback loops to stay clean.
